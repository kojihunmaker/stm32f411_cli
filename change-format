---
# STM32/Embedded C++ Style Guide
Language: Cpp
BasedOnStyle: LLVM

# 들여쓰기 설정
IndentWidth: 4
TabWidth: 4
UseTab: Never

# 중괄호 스타일 (Kernighan & Ritchie 스타일)
BreakBeforeBraces: Custom
BraceWrapping:
  AfterClass: false
  AfterControlStatement: false
  AfterEnum: false
  AfterFunction: true
  AfterNamespace: false
  AfterStruct: false
  AfterUnion: false
  BeforeElse: false
  IndentBraces: false

# 한 줄 최대 길이
ColumnLimit: 100

# 포인터 위치 (int* ptr 방식)
PointerAlignment: Right

# 기타 세부 설정
AlignAfterOpenBracket: Align
AlignConsecutiveAssignments: false
AlignConsecutiveDeclarations: false
AllowShortFunctionsOnASingleLine: None
AllowShortIfStatementsOnASingleLine: false
IncludeBlocks: Regroup
SortIncludes: true
---